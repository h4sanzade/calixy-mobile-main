<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingBottom="12dp">

    <!-- Bot avatar -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="2dp"
        android:src="@drawable/ic_bot_avatar"
        android:background="@drawable/bg_avatar"
        android:padding="1dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1">

        <!-- Text bubble -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bubble_bot"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="260dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/inter_medium"
                android:lineSpacingMultiplier="1.4"/>

        </LinearLayout>

        <!-- BMI Card -->
        <LinearLayout
            android:id="@+id/cardBmi"
            android:layout_width="290dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_elevated"
            android:orientation="vertical"
            android:padding="18dp"
            android:visibility="gone"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvBmiValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_extrabold"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvBmiVerdict"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_medium"
                    android:background="@drawable/bg_chip_selected"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"/>

            </LinearLayout>

            <ProgressBar
                android:id="@+id/bmiProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progressDrawable="@null"
                android:progressTint="@color/accent_primary"
                android:progressBackgroundTint="@color/stroke_subtle"/>

            <TextView
                android:id="@+id/tvBmiZones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Analysis Card -->
        <LinearLayout
            android:id="@+id/cardAnalysis"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            android:elevation="2dp">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/weightChart"
                android:layout_width="match_parent"
                android:layout_height="160dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="@color/stroke_subtle"/>

            <TextView
                android:id="@+id/tvStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:lineSpacingMultiplier="1.6"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>