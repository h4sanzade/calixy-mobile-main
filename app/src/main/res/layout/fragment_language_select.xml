<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_lang_top_accent">

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="-70dp"
        android:layout_marginEnd="-70dp"
        android:alpha="0.10"
        android:background="@drawable/bg_circle_deco"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginStart="-50dp"
        android:layout_marginBottom="-50dp"
        android:alpha="0.07"
        android:background="@drawable/bg_circle_deco"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <LinearLayout
        android:id="@+id/heroGroup"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomSheet">

        <FrameLayout
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center"
                android:alpha="0.20"
                android:background="@drawable/bg_logo_glow"/>

            <View
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_avatar"/>

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bot_avatar"
                android:contentDescription="@string/app_name"/>

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@android:color/white"
            android:textSize="34sp"
            android:fontFamily="@font/inter_extrabold"
            android:letterSpacing="-0.02"/>

    </LinearLayout>

    <!-- Bottom Sheet card -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_sheet_handle"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/select_language"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:fontFamily="@font/inter_bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/select_language_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:id="@+id/langContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <!-- Azerbaijani -->
            <LinearLayout
                android:id="@+id/itemAz"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_lang_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="🇦🇿"
                    android:textSize="20sp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Azərbaycan"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_medium"/>

                <ImageView
                    android:id="@+id/radioAz"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_radio_unselected"/>

            </LinearLayout>

            <!-- Turkish -->
            <LinearLayout
                android:id="@+id/itemTr"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_lang_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="🇹🇷"
                    android:textSize="20sp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Türkçe"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_medium"/>

                <ImageView
                    android:id="@+id/radioTr"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_radio_unselected"/>

            </LinearLayout>

            <!-- English (default selected) -->
            <LinearLayout
                android:id="@+id/itemEn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_lang_item_selected"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="🇬🇧"
                    android:textSize="20sp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="English"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_medium"/>

                <ImageView
                    android:id="@+id/radioEn"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_radio_selected"/>

            </LinearLayout>

            <!-- Russian -->
            <LinearLayout
                android:id="@+id/itemRu"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_lang_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="🇷🇺"
                    android:textSize="20sp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Русский"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_medium"/>

                <ImageView
                    android:id="@+id/radioRu"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_radio_unselected"/>

            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinueLang"
            style="@style/Widget.CalixyAI.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_continue"
            android:fontFamily="@font/inter_bold"
            android:textSize="16sp"
            app:cornerRadius="100dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/lang_change_later"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>