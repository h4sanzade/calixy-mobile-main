<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/screen_min_height"
            android:paddingHorizontal="28dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp">

            <!-- Back -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_card"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/text_primary"
                android:padding="11dp"
                android:contentDescription="Back"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- Envelope icon card -->
            <LinearLayout
                android:id="@+id/illustrationCard"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card_elevated"
                android:layout_marginTop="48dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✉"
                    android:textSize="44sp"
                    android:textColor="@color/accent_primary"/>
            </LinearLayout>

            <!-- Heading -->
            <TextView
                android:id="@+id/tvHeading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/verify_heading"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:fontFamily="@font/inter_extrabold"
                android:letterSpacing="-0.02"
                android:gravity="center"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/illustrationCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Description -->
            <LinearLayout
                android:id="@+id/descGroup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/tvHeading"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/verify_description"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="user@example.com"
                    android:textColor="@color/accent_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/verify_description_2"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- OTP 6-box row -->
            <LinearLayout
                android:id="@+id/otpContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/descGroup"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <EditText
                    android:id="@+id/otp1"
                    android:layout_width="46dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_extrabold"
                    android:textAlignment="center"
                    android:imeOptions="actionNext"
                    android:cursorVisible="false"/>

                <EditText
                    android:id="@+id/otp2"
                    android:layout_width="46dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_extrabold"
                    android:textAlignment="center"
                    android:imeOptions="actionNext"
                    android:cursorVisible="false"/>

                <EditText
                    android:id="@+id/otp3"
                    android:layout_width="46dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_extrabold"
                    android:textAlignment="center"
                    android:imeOptions="actionNext"
                    android:cursorVisible="false"/>

                <EditText
                    android:id="@+id/otp4"
                    android:layout_width="46dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_extrabold"
                    android:textAlignment="center"
                    android:imeOptions="actionNext"
                    android:cursorVisible="false"/>

                <EditText
                    android:id="@+id/otp5"
                    android:layout_width="46dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_extrabold"
                    android:textAlignment="center"
                    android:imeOptions="actionNext"
                    android:cursorVisible="false"/>

                <EditText
                    android:id="@+id/otp6"
                    android:layout_width="46dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_extrabold"
                    android:textAlignment="center"
                    android:imeOptions="actionDone"
                    android:cursorVisible="false"/>

            </LinearLayout>

            <!-- OTP error -->
            <TextView
                android:id="@+id/tvOtpError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/error"
                android:textSize="13sp"
                android:fontFamily="@font/inter_regular"
                android:gravity="center"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/otpContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Status message -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_primary"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvOtpError"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Verify button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerify"
                style="@style/Widget.CalixyAI.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:text="@string/btn_verify"
                android:textSize="15sp"
                android:fontFamily="@font/inter_bold"
                app:cornerRadius="100dp"
                app:layout_constraintTop_toBottomOf="@id/tvStatus"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Resend button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResend"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:text="@string/btn_resend"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium"
                android:textColor="@color/accent_primary"
                app:strokeColor="@color/accent_primary"
                app:strokeWidth="1dp"
                app:cornerRadius="100dp"
                app:layout_constraintTop_toBottomOf="@id/btnVerify"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Cooldown row -->
            <LinearLayout
                android:id="@+id/cooldownGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@id/btnResend"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/resend_available_in"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_regular"/>

                <TextView
                    android:id="@+id/tvCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:60"
                    android:textColor="@color/accent_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_bold"/>
            </LinearLayout>

            <!-- Bottom login link -->
            <LinearLayout
                android:id="@+id/loginRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/cooldownGroup"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/already_verified"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_regular"/>

                <TextView
                    android:id="@+id/tvGoToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/go_to_login"
                    android:textColor="@color/accent_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>