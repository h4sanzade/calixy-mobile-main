<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/screen_min_height"
            android:paddingHorizontal="28dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp">

            <!-- Back button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_card"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/text_primary"
                android:padding="11dp"
                android:contentDescription="Back"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- REQUEST STEP -->
            <LinearLayout
                android:id="@+id/stepRequest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/btnBack"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Icon -->
                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:gravity="center"
                    android:background="@drawable/bg_card_elevated"
                    android:layout_marginBottom="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔑"
                        android:textSize="30sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_heading"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:fontFamily="@font/inter_extrabold"
                    android:letterSpacing="-0.02"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_subheading"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="36dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_email"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_medium"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.CalixyAI.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_edit_text"
                        android:hint="@string/hint_email"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_regular"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tvEmailError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/error"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_regular"
                    android:visibility="gone"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendReset"
                    style="@style/Widget.CalixyAI.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="28dp"
                    android:text="@string/btn_send_reset"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_bold"
                    app:cornerRadius="100dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/remember_password"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"/>

                    <TextView
                        android:id="@+id/tvGoToLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/go_to_login"
                        android:textColor="@color/accent_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- SUCCESS STEP -->
            <LinearLayout
                android:id="@+id/stepSuccess"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginTop="60dp"
                app:layout_constraintTop_toBottomOf="@id/btnBack"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:gravity="center"
                    android:background="@drawable/bg_card_elevated"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="44sp"
                        android:textColor="@color/accent_primary"
                        android:fontFamily="@font/inter_bold"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/success_heading"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:fontFamily="@font/inter_extrabold"
                    android:letterSpacing="-0.02"
                    android:gravity="center"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/success_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="40dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackToLogin"
                    style="@style/Widget.CalixyAI.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_back_to_login"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_bold"
                    app:cornerRadius="100dp"/>

                <TextView
                    android:id="@+id/tvResendFromSuccess"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/resend_from_success"
                    android:textColor="@color/accent_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_medium"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="20dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>