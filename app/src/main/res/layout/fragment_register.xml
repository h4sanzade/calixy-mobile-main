<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="700dp"
        android:paddingHorizontal="28dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <!-- Logo / Brand -->
        <LinearLayout
            android:id="@+id/brandGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="36dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_bot_avatar"
                android:background="@drawable/bg_avatar"
                android:padding="2dp"
                android:contentDescription="@string/app_name"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="@font/inter_extrabold"
                android:letterSpacing="-0.01"/>
        </LinearLayout>

        <!-- Heading -->
        <TextView
            android:id="@+id/tvHeading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Create your account."
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:fontFamily="@font/inter_extrabold"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/brandGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvSubheading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Join CalixyAI and start your wellness journey."
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:fontFamily="@font/inter_regular"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Full Name Field -->
        <LinearLayout
            android:id="@+id/nameGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubheading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilName"
                style="@style/Widget.CalixyAI.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_edit_text"
                    android:hint="Enter your full name"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular"
                    android:inputType="textPersonName|textCapWords"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Email Field -->
        <LinearLayout
            android:id="@+id/emailGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/nameGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.CalixyAI.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_edit_text"
                    android:hint="name@example.com"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Password Field -->
        <LinearLayout
            android:id="@+id/passwordGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/emailGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.CalixyAI.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_edit_text"
                    android:hint="••••••••"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular"
                    android:inputType="textPassword"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password strength hint -->
            <TextView
                android:id="@+id/tvPasswordHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Use at least 8 characters, including a number."
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="@font/inter_regular"/>
        </LinearLayout>

        <!-- Confirm Password Field -->
        <LinearLayout
            android:id="@+id/confirmPasswordGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/passwordGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm Password"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilConfirmPassword"
                style="@style/Widget.CalixyAI.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_edit_text"
                    android:hint="••••••••"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular"
                    android:inputType="textPassword"
                    android:imeOptions="actionDone"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Error message -->
            <TextView
                android:id="@+id/tvRegisterError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/error"
                android:textSize="13sp"
                android:fontFamily="@font/inter_regular"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Sign Up Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignUp"
            style="@style/Widget.CalixyAI.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="Sign Up"
            android:textSize="16sp"
            android:fontFamily="@font/inter_bold"
            app:cornerRadius="100dp"
            app:layout_constraintTop_toBottomOf="@id/confirmPasswordGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- OR divider -->
        <LinearLayout
            android:id="@+id/dividerRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/btnSignUp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/stroke_subtle"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OR"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="@font/inter_medium"
                android:paddingHorizontal="14dp"
                android:letterSpacing="0.08"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/stroke_subtle"/>
        </LinearLayout>

        <!-- Google Sign Up -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogle"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="Sign up with Google"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="@font/inter_medium"
            app:strokeColor="@color/stroke_subtle"
            app:strokeWidth="1dp"
            app:cornerRadius="100dp"
            app:icon="@android:drawable/stat_sys_warning"
            app:iconTint="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/dividerRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Login link -->
        <LinearLayout
            android:id="@+id/loginRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/btnGoogle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"/>

            <TextView
                android:id="@+id/tvGoToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log In"
                android:textColor="@color/accent_primary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_bold"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Terms -->
        <TextView
            android:id="@+id/tvTerms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="By signing up, you agree to our Terms of Service and Privacy Policy."
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            app:layout_constraintTop_toBottomOf="@id/loginRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
