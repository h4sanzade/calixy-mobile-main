<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:id="@+id/chatHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp"
        android:background="@color/background_surface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_bot_avatar"
            android:background="@drawable/bg_avatar"
            android:padding="2dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calixy"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/inter_extrabold"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/online_status"
                android:textColor="@color/accent_primary"
                android:fontFamily="@font/inter_medium"
                android:textSize="12sp"/>

        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/stroke_subtle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chatHeader"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/inputContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"/>

    <!-- Input panel -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_input"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Slider panel: HEIGHT + WEIGHT -->
        <LinearLayout
            android:id="@+id/sliderPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@drawable/bg_card_elevated"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <!-- HEIGHT row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/height_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:fontFamily="@font/inter_regular"
                    android:letterSpacing="0.06"/>

                <TextView
                    android:id="@+id/tvHeightValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="170 cm"
                    android:textColor="@color/accent_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/inter_regular"
                    android:textStyle="bold"/>

            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderHeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="140"
                android:valueTo="220"
                android:value="170"
                android:stepSize="1"
                app:thumbColor="@color/accent_primary"
                app:trackColorActive="@color/accent_primary"
                app:trackColorInactive="@color/stroke_subtle"
                app:thumbRadius="10dp"
                app:trackHeight="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="140 cm"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/text_tertiary" android:textSize="11sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="220 cm"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stroke_subtle"
                android:layout_marginBottom="18dp"/>

            <!-- WEIGHT row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/weight_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:fontFamily="@font/inter_regular"
                    android:letterSpacing="0.06"/>

                <TextView
                    android:id="@+id/tvWeightValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="70 kg"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/accent_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="30"
                android:valueTo="200"
                android:value="70"
                android:stepSize="0.5"
                app:thumbColor="@color/accent_primary"
                app:trackColorActive="@color/accent_primary"
                app:trackColorInactive="@color/stroke_subtle"
                app:thumbRadius="10dp"
                app:trackHeight="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="30 kg"
                    android:textColor="@color/text_tertiary" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="200 kg"
                    android:textColor="@color/text_tertiary" android:textSize="11sp"/>
            </LinearLayout>

            <!-- Confirm button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmSliders"
                style="@style/Widget.CalixyAI.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/slider_confirm"/>

        </LinearLayout>

        <!-- Chips / multi-select panel -->
        <LinearLayout
            android:id="@+id/selectionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputCustom"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edit_text"
                android:hint="@string/type_custom"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinueSelections"
                style="@style/Widget.CalixyAI.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter_bold"
                android:text="@string/continue_arrow"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Text input row -->
        <LinearLayout
            android:id="@+id/inputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputMessage"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_edit_text"
                android:hint="@string/type_answer"
                android:paddingHorizontal="16dp"
                android:fontFamily="@font/inter_medium"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp"
                android:inputType="textCapSentences"/>

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_send_button"
                android:src="@android:drawable/ic_menu_send"
                android:tint="@android:color/white"
                android:contentDescription="@string/send"
                android:padding="12dp"/>

        </LinearLayout>

        <!-- Problem 4: inline validation error message -->
        <TextView
            android:id="@+id/tvInputError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/error"
            android:fontFamily="@font/inter_regular"
            android:textSize="13sp"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUnlockPlan"
            style="@style/Widget.CalixyAI.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="@string/unlock_plan"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>