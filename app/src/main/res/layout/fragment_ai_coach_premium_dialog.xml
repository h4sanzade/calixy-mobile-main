<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialogRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_ai_coach_dialog"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="28dp"
    android:elevation="12dp">

    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@drawable/ic_bot_avatar"
            android:textSize="32sp"
            android:elevation="5dp" />

        <FrameLayout
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="0dp"
            android:background="@drawable/bg_badge_circle"
            android:elevation="6dp">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="center"
                android:src="@drawable/bg_btn_green_gradient" />

        </FrameLayout>

    </FrameLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/inter_extrabold"
        android:gravity="center"
        android:letterSpacing="-0.02"
        android:text="Meet your AI Coach"
        android:textColor="#1B3A1F"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconContainer" />

    <!-- ── SUBTITLE ───────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter_regular"
        android:gravity="center"
        android:lineSpacingMultiplier="1.55"
        android:text="Transform your data into a personalized wellness roadmap. Calixy learns your habits to optimize your lifestyle."
        android:textColor="#6B7280"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- ── CHIPS ROW ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/chipsRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <!-- Chip 1: Goals -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_pill_chip"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="🎯 Goals"
            android:textColor="#2E7D32"
            android:textSize="13sp" />

        <!-- Chip 2: Diet -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_pill_chip"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="🥗 Diet"
            android:textColor="#2E7D32"
            android:textSize="13sp" />

        <!-- Chip 3: Macros -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_pill_chip"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="📊 Macros"
            android:textColor="#2E7D32"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ── DIVIDER ─────────────────────────────────────────────────────────── -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="#F0F0F0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chipsRow" />

    <!-- ── SETUP BUTTON ────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/btnSetupCoach"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_btn_green_ripple"
        android:clickable="true"
        android:elevation="4dp"
        android:focusable="true"
        android:fontFamily="@font/inter_bold"
        android:gravity="center"
        android:text="Setup with AI Coach →"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

</androidx.constraintlayout.widget.ConstraintLayout>