    <View android:id="@+id/dotOne" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="6dp" android:background="@drawable/bg_typing_dot" />
    <View android:id="@+id/dotTwo" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="6dp" android:background="@drawable/bg_typing_dot" />
    <View android:id="@+id/dotThree" android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_typing_dot" />
</LinearLayout>
