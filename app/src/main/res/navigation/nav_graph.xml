<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">


    <fragment
        android:id="@+id/splashFragment"
        android:name="com.calixyai.ui.splash.SplashFragment"
        android:label="Splash">
        <action android:id="@+id/action_splashFragment_to_languageSelectFragment"
            app:destination="@id/languageSelectFragment"
            app:popUpTo="@id/splashFragment" app:popUpToInclusive="true"/>
        <action android:id="@+id/action_splashFragment_to_onboardingFragment"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/splashFragment" app:popUpToInclusive="true"/>
        <action android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment" app:popUpToInclusive="true"/>
        <action android:id="@+id/action_splashFragment_to_chatSetupFragment"
            app:destination="@id/chatSetupFragment"
            app:popUpTo="@id/splashFragment" app:popUpToInclusive="true"/>
        <action android:id="@+id/action_splashFragment_to_paymentFragment"
            app:destination="@id/paymentFragment"
            app:popUpTo="@id/splashFragment" app:popUpToInclusive="true"/>
        <action android:id="@+id/action_splashFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment" app:popUpToInclusive="true"/>
    </fragment>

    <!-- ── Language ───────────────────────────────────────────────────────────── -->

    <fragment
        android:id="@+id/languageSelectFragment"
        android:name="com.calixyai.ui.language.LanguageSelectFragment"
        android:label="Language">
        <action
            android:id="@+id/action_languageSelectFragment_to_onboardingFragment"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/languageSelectFragment" app:popUpToInclusive="true"/>
    </fragment>

    <!-- ── Onboarding ────────────────────────────────────────────────────────── -->

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.calixyai.ui.onboarding.OnboardingFragment"
        android:label="Onboarding">

        <action android:id="@+id/action_onboardingFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/onboardingFragment" app:popUpToInclusive="true"/>
    </fragment>

    <!-- ── Auth ──────────────────────────────────────────────────────────────── -->

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.calixyai.ui.auth.login.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment"/>
        <action
            android:id="@+id/action_loginFragment_to_forgotPasswordFragment"
            app:destination="@id/forgotPasswordFragment"/>
        <action
            android:id="@+id/action_loginFragment_to_emailVerifyFragment"
            app:destination="@id/emailVerifyFragment">
            <argument
                android:name="email"
                app:argType="string"
                android:defaultValue=""/>
        </action>
        <action
            android:id="@+id/action_loginFragment_to_chatSetupFragment"
            app:destination="@id/chatSetupFragment"
            app:popUpTo="@id/loginFragment" app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.calixyai.ui.auth.register.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_registerFragment_to_emailVerifyFragment"
            app:destination="@id/emailVerifyFragment">
            <argument
                android:name="email"
                app:argType="string"
                android:defaultValue=""/>
        </action>
    </fragment>

    <fragment
        android:id="@+id/emailVerifyFragment"
        android:name="com.calixyai.ui.auth.verify.EmailVerifyFragment"
        android:label="Verify Email">
        <argument
            android:name="email"
            app:argType="string"
            android:defaultValue=""/>
        <action
            android:id="@+id/action_emailVerifyFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment" app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.calixyai.ui.auth.forgot.ForgotPasswordFragment"
        android:label="Forgot Password"/>

    <!-- ── Post-Auth Setup ────────────────────────────────────────────────────── -->

    <fragment android:id="@+id/chatSetupFragment"
        android:name="com.calixyai.ui.chatsetup.ChatSetupFragment"
        android:label="Chat Setup">
        <action android:id="@+id/action_chatSetupFragment_to_paymentFragment"
            app:destination="@id/paymentFragment"
            app:popUpTo="@id/chatSetupFragment" app:popUpToInclusive="true"/>
    </fragment>

    <fragment android:id="@+id/paymentFragment"
        android:name="com.calixyai.ui.payment.PaymentFragment"
        android:label="Payment">
        <action android:id="@+id/action_paymentFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/paymentFragment" app:popUpToInclusive="true"/>
    </fragment>

    <!-- ── Main ───────────────────────────────────────────────────────────────── -->

    <fragment android:id="@+id/homeFragment"
        android:name="com.calixyai.ui.home.HomeFragment"
        android:label="Home"/>

    <fragment android:id="@+id/tab_plan"
        android:name="com.calixyai.ui.navigation.SimplePlaceholderFragment"
        android:label="Plan">
        <argument android:name="arg_title" app:argType="string" android:defaultValue="Plan"/>
    </fragment>
    <fragment android:id="@+id/tab_progress"
        android:name="com.calixyai.ui.navigation.SimplePlaceholderFragment"
        android:label="Progress">
        <argument android:name="arg_title" app:argType="string" android:defaultValue="Progress"/>
    </fragment>
    <fragment android:id="@+id/tab_profile"
        android:name="com.calixyai.ui.navigation.SimplePlaceholderFragment"
        android:label="Profile">
        <argument android:name="arg_title" app:argType="string" android:defaultValue="Profile"/>
    </fragment>

</navigation>