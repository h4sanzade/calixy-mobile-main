<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.CalixyAI" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/background_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorSurface">@color/background_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/background_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Primary CTA Button -->
    <style name="Widget.CalixyAI.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Ghost / Outline Button -->
    <style name="Widget.CalixyAI.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/accent_primary</item>
        <item name="strokeColor">@color/accent_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.CalixyAI.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/stroke_subtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- TextInput style -->
    <style name="Widget.CalixyAI.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox.Dense">
        <item name="boxBackgroundColor">@color/background_input</item>
        <item name="boxStrokeColor">@color/stroke_subtle</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">@color/text_hint</item>
    </style>

    <!-- Chip style -->
    <style name="Widget.CalixyAI.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/background_elevated</item>
        <item name="chipStrokeColor">@color/stroke_subtle</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="chipCornerRadius">12dp</item>
    </style>

</resources>