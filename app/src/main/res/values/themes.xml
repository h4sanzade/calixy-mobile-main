<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CalixyAI" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="android:windowBackground">@color/background_primary</item>
    </style>

    <style name="Widget.CalixyAI.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/background_primary</item>
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>